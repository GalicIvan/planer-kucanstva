APP_NAME="Planer kucanstva"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=planer_kucanstva
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file
FILESYSTEM_DISK=public

# Used by Sanctum if you ever switch to cookie-based SPA auth.
# Not required for the default Bearer-token setup used by this project.
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# Frontend URL (used in CORS config / mail links if needed)
FRONTEND_URL=http://localhost:5173
